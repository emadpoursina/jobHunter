# OS
.DS_Store

# Local-only folder (exports, PDFs, screenshots, etc.)
non-repo-files/

# --- Generated by agents (regeneratable from profile + offer files) ---
phase2/documents/generated/*
!phase2/documents/generated/.gitkeep
!phase2/documents/generated/README.md

# --- Collected / parsed offer files (job-collector output) ---
phase2/offers/by-country/**
!phase2/offers/by-country/.gitkeep

# --- Application notes (copy from _application-template.md per role) ---
phase2/applications/*
!phase2/applications/README.md
!phase2/applications/_application-template.md
!phase2/applications/pipeline.md

# --- Stray job-collector output when REPO_ROOT was misconfigured ---
tools/job-collector/phase2/

# --- Personal networking data ---
networking/contacts.md
networking/outreach-log.md

# --- Raw profile drafts & scratch (templates in raw/ stay tracked) ---
raw/Master_Profile_v*.md
raw/*-draft*.md
raw/*_draft*.md

# --- Secrets / local env (if added later) ---
.env
.env.*
!.env.example

# --- Tool runtime data and secrets ---
tools/*/node_modules/
tools/*/data/
tools/*/.env

# OS
.DS_Store

# Local-only folder (exports, PDFs, screenshots, etc.)
non-repo-files/

# --- Generated by agents (regeneratable from profile + offer files) ---
documents/generated/*
!documents/generated/.gitkeep
!documents/generated/README.md

# --- Application notes (copy from _application-template.md per role) ---
applications/*
!applications/README.md
!applications/_application-template.md
!applications/pipeline.md

# --- Personal networking data ---
networking/contacts.md
networking/outreach-log.md

# --- Raw profile drafts & scratch (templates in raw/ stay tracked) ---
raw/Master_Profile_v*.md
raw/*-draft*.md
raw/*_draft*.md

# --- Secrets / local env (if added later) ---
.env
.env.*
!.env.example

# --- Tool runtime data and secrets ---
tools/*/node_modules/
tools/*/data/
tools/*/.env
